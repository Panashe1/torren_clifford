<% content_for :title, "Torren Clifford — Architectural Photography" %>

<% if @hero_project %>
  <section class="hero">
    <img src="<%= @hero_project.cover_url %>" alt="<%= @hero_project.title %>" />
    <div class="hero-caption"><%= @hero_project.title %> / <%= @hero_project.architect %></div>
  </section>
<% end %>

<div class="section-title">Select Projects</div>

<div class="grid">
  <% @projects.each do |project| %>
    <%= link_to project_path(project), class: "card" do %>
      <img src="<%= project.cover_url %>" alt="<%= project.title %>" loading="lazy" />
      <div class="card-info">
        <div class="card-title"><%= project.title %></div>
        <div class="card-sub"><%= project.architect %></div>
      </div>
    <% end %>
  <% end %>
</div>

