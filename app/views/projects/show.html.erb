<% content_for :title, "#{@project.title} — Torren Clifford" %>

<div class="project-viewer" id="projectViewer">

  <!-- Images -->
  <div class="project-slides" id="projectSlides">
    <% @images.each_with_index do |img, i| %>
      <div class="project-slide <%= i == 0 ? 'active' : '' %>" data-index="<%= i %>">
        <img src="<%= img.display_url %>"
             alt="<%= @project.title %> — image <%= i + 1 %>" />
      </div>
    <% end %>
  </div>

  <!-- Click zones -->
  <div class="click-prev" id="clickPrev"></div>
  <div class="click-next" id="clickNext"></div>

  <!-- Arrow indicators -->
  <div class="arrow arrow-left" id="arrowLeft">&#8592;</div>
  <div class="arrow arrow-right" id="arrowRight">&#8594;</div>

  <!-- Project info -->
  <div class="project-info-bar">
    <div class="project-info-title"><%= @project.title %></div>
    <div class="project-info-meta"><%= @project.architect %></div>
    <div class="project-info-counter">
      <span id="currentSlide">1</span> / <%= @images.length %>
    </div>
  </div>

  <!-- Close -->
  <%= link_to "✕", root_path, class: "project-close" %>

</div>

<style>
  html, body { height: 100%; overflow: hidden; }
  main { padding: 0; height: calc(100vh - 56px); }

  .project-viewer {
    position: relative;
    width: 100%;
    height: 100%;
    background: #f5f5f0;
    overflow: hidden;
  }

  /* Slides */
  .project-slides {
    position: absolute;
    inset: 0;
    bottom: 52px;
  }

  .project-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .project-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .project-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    padding: 32px 80px;
  }

  /* Click zones */
  .click-prev,
  .click-next {
    position: absolute;
    top: 0;
    bottom: 52px;
    width: 50%;
    z-index: 10;
    cursor: pointer;
  }

  .click-prev { left: 0; cursor: w-resize; }
  .click-next { right: 0; cursor: e-resize; }

  /* Arrows */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 11;
    font-size: 20px;
    color: var(--black);
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    letter-spacing: 0;
  }

  .project-viewer:hover .arrow { opacity: 0.4; }
  .arrow-left  { left: 24px; }
  .arrow-right { right: 24px; }

  .arrow.hidden { opacity: 0 !important; }

  /* Info bar */
  .project-info-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 52px;
    border-top: 1px solid var(--border);
    background: #fff;
    display: flex;
    align-items: center;
    padding: 0 32px;
    gap: 24px;
    z-index: 20;
  }

  .project-info-title {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--black);
  }

  .project-info-meta {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light);
  }

  .project-info-counter {
    margin-left: auto;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--light);
  }

  /* Close */
  .project-close {
    position: absolute;
    top: 16px;
    right: 20px;
    z-index: 30;
    font-size: 18px;
    color: var(--black);
    text-decoration: none;
    line-height: 1;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .project-close:hover { opacity: 1; }
</style>

<script>
  // Wrapped in an IIFE so nothing leaks to the global scope — this lets the
  // viewer re-initialise correctly on Turbo navigations, not just hard refreshes.
  (function () {
    const slides = document.querySelectorAll('.project-slide');
    if (!slides.length) return;

    const counter = document.getElementById('currentSlide');
    const arrowLeft = document.getElementById('arrowLeft');
    const arrowRight = document.getElementById('arrowRight');
    let current = 0;

    function goTo(n) {
      slides[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      counter.textContent = current + 1;
      arrowLeft.classList.toggle('hidden', current === 0);
      arrowRight.classList.toggle('hidden', current === slides.length - 1);
    }

    document.getElementById('clickNext').addEventListener('click', () => {
      if (current < slides.length - 1) goTo(current + 1);
    });

    document.getElementById('clickPrev').addEventListener('click', () => {
      if (current > 0) goTo(current - 1);
    });

    function onKeydown(e) {
      if (e.key === 'ArrowRight') goTo(current + 1);
      if (e.key === 'ArrowLeft')  goTo(current - 1);
      if (e.key === 'Escape')     window.location = '<%= root_path %>';
    }
    document.addEventListener('keydown', onKeydown);

    // Remove the document-level listener when Turbo navigates away so stale
    // handlers from previous project pages don't pile up.
    document.addEventListener('turbo:before-render', function cleanup() {
      document.removeEventListener('keydown', onKeydown);
      document.removeEventListener('turbo:before-render', cleanup);
    });

    // Init arrow visibility
    arrowLeft.classList.add('hidden');
    if (slides.length <= 1) arrowRight.classList.add('hidden');
  })();
</script>
